{
  "name": "mosaic-module-discord",
  "version": "1.0.0",
  "description": "Discord bot module for the Mosaic framework — idea capture via slash commands and watched channels",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev":           "tsx watch index.ts",
    "build":         "tsc",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "discord.js":         "^14.26.4",
    "express":            "^5.2.1"
  },
  "devDependencies": {
    "@types/express":      "^5.0.6",
    "@types/node":         "^25.9.3",
    "@types/supertest":    "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "better-sqlite3":      "^12.10.0",
    "supertest":           "^7.2.2",
    "tsx":                 "^4.22.4",
    "typescript":          "^6.0.3",
    "vitest":              "^4.1.8"
  }
}
