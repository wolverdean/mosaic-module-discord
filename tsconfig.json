{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "outDir":            "./dist",
    "strict":            true,
    "skipLibCheck":      true,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "paths": {
      "@mosaic/sdk": ["../mosaic-framework/types.ts"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
